{
  "name": "guy",
  "version": "0.0.0",
  "type": "module",
  "imports": {
    "#*": "./agent/*",
    "#evals/*": "./evals/*"
  },
  "scripts": {
    "build": "eve build",
    "dev": "eve dev --port 3000",
    "runner": "NODE_NO_WARNINGS=1 node --env-file-if-exists=.env --env-file-if-exists=.env.local --experimental-transform-types runner/src/main.ts",
    "runner:debug": "NODE_NO_WARNINGS=1 LOG_LEVEL=debug node --env-file-if-exists=.env --env-file-if-exists=.env.local --experimental-transform-types runner/src/main.ts",
    "runner:debug-message": "NODE_NO_WARNINGS=1 LOG_LEVEL=debug RUNNER_DEBUG_MESSAGE_CHECK=1 node --env-file-if-exists=.env --env-file-if-exists=.env.local --experimental-transform-types runner/src/main.ts",
    "runner:json": "NODE_NO_WARNINGS=1 LOG_FORMAT=json node --env-file-if-exists=.env --env-file-if-exists=.env.local --experimental-transform-types runner/src/main.ts",
    "runner:watch": "NODE_NO_WARNINGS=1 node --env-file-if-exists=.env --env-file-if-exists=.env.local --experimental-transform-types --watch runner/src/main.ts",
    "start": "eve start --port 3000",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "prepare": "node scripts/inline-cowsay-cows.mjs"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^3.0.1",
    "@ai-sdk/provider-utils": "5.0.1",
    "@libsql/client": "^0.17.4",
    "@vercel/connect": "0.2.2",
    "ai": "7.0.0-beta.178",
    "eve": "^0.11.6",
    "microsandbox": "^0.5.7",
    "nanoid": "5.1.11",
    "vercel-minimax-ai-provider": "^0.0.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.x",
    "@typescript/native-preview": "7.0.0-dev.20260523.1",
    "just-bash": "^3.0.1"
  },
  "overrides": {
    "ai": "7.0.0-beta.178"
  },
  "resolutions": {
    "ai": "7.0.0-beta.178"
  },
  "engines": {
    "node": "24.x"
  }
}